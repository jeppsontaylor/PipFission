# ==== Heavy data — kept local, NEVER committed ====
# `data/` carries the live DuckDB, logs, parquet archives, and per-trade
# JSON snapshots — none of which belong in git.
data/

# ==== Secrets — NEVER commit ====
.env
.env.*
*.pem
*.key
secrets.json
.aws/

# ==== Raw collector dumps (huge) ====
oanda_data/
data_chunks/

# ==== Build artifacts ====
server/target/
dashboard/node_modules/
dashboard/dist/

# ==== Python ====
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==== Research artifacts (heavy, rebuildable) ====
research/artifacts/
research/.optuna/

# ==== Loose images / scratch generated by ad-hoc scripts ====
*.png
*.jpg
*.jpeg
collector.log
collector.pid
*.bak
*.tmp

# ==== IDE / OS ====
.DS_Store
.vscode/
.idea/
*.swp

# ==== Claude / agent scratch ====
.claude/

# CWD-pollution guard: pipeline runs from research/ create this
research/trade_logs/

# Defence-in-depth: any crate-relative trade_logs path
server/crates/*/trade_logs/
